<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Toolbar (elevation gives shadow over WebView) -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="4dp"
        android:orientation="vertical">

        <!-- Address bar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/nav_back"
                android:src="@drawable/ic_back"
                android:tint="?attr/colorControlNormal" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/nav_forward"
                android:src="@drawable/ic_forward"
                android:tint="?attr/colorControlNormal" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/address_bar_bg"
                android:hint="@string/address_bar_hint"
                android:imeOptions="actionGo|flagNoExtractUi"
                android:inputType="textUri|textNoSuggestions"
                android:maxLines="1"
                android:paddingHorizontal="12dp"
                android:scrollHorizontally="true"
                android:selectAllOnFocus="true"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/btnStopRefresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/nav_refresh"
                android:src="@drawable/ic_refresh"
                android:tint="?attr/colorControlNormal" />

            <ImageButton
                android:id="@+id/btnBookmark"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu_bookmarks"
                android:src="@drawable/ic_bookmark_border"
                android:tint="?attr/colorControlNormal" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu_settings"
                android:src="@drawable/ic_settings"
                android:tint="?attr/colorControlNormal" />
        </LinearLayout>

        <!-- Loading progress indicator -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:visibility="invisible" />

        <!-- Tab bar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tabContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- History suggestions dropdown (GONE by default) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSuggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:visibility="gone" />

    <!-- WebView lives here -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
